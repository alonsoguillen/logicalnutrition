---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductMockup from '../components/ProductMockup.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import FAQ from '../components/FAQ.astro';
import Newsletter from '../components/Newsletter.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { brandTestimonials } from '../data/testimonials';
import HeroCanvas from '../components/HeroCanvas.astro';

const supplements = await getCollection('supplements');
supplements.sort((a, b) => a.data.order - b.data.order);
const featuredSupplements = supplements.filter((s) => s.data.featured).slice(0, 3);

const testimonials = brandTestimonials;

const homeFaqs = [
  {
    question: '¿Dónde se fabrican los productos?',
    answer: 'Trabajamos con proveedores certificados bajo estándares GMP y BPF. Cada lote es analizado para garantizar pureza, potencia y ausencia de contaminantes.',
  },
  {
    question: '¿Hacen envíos a todo el Perú?',
    answer: 'Sí. Realizamos envíos a nivel nacional a través de courier. El tiempo estimado es de 2 a 5 días hábiles dependiendo de la ciudad.',
  },
  {
    question: '¿Cómo sé que los productos son realmente puros?',
    answer: 'Cada producto cuenta con análisis de pureza documentado. Además, publicamos de forma transparente los ingredientes, dosis y referencias científicas.',
  },
  {
    question: '¿Puedo combinar creatina con L-citrulina?',
    answer: 'Sí. Ambos suplementos tienen mecanismos complementarios y pueden tomarse juntos antes del entrenamiento o en cualquier momento del día.',
  },
];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Logical Nutrition',
  url: Astro.site,
  logo: `${Astro.site}/favicon.svg`,
  description: 'Suplementos con respaldo científico y resultados probados. Sin modas ni placebos. Pureza garantizada.',
  sameAs: [],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Logical Nutrition',
  url: Astro.site,
};
---

<Layout
  title="Logical Nutrition — Ciencia pura. Resultados reales."
  description="Suplementos con respaldo científico y resultados probados. Sin modas ni placebos. Pureza garantizada."
  canonical="/"
  structuredData={[organizationSchema, websiteSchema]}
>
  <div class="page">
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="atmospheric-glow"></div>
        <HeroCanvas />
        <div class="container hero-grid">
          <div class="hero-content">
            <p class="hero-eyebrow animate-on-scroll">Suplementación basada en evidencia</p>
            <h1 class="hero-title reveal-text">
              <span class="line"><span class="line-inner">Ciencia pura.</span></span>
              <span class="line"><span class="line-inner text-serif">Resultados reales.</span></span>
            </h1>
            <p class="hero-subtitle animate-on-scroll stagger-2">
              Compuestos puros, dosis efectivas y evidencia verificable. Sin modas pasajeras, sin promesas vacías: solo lo que la ciencia respalda.
            </p>
            <div class="hero-actions animate-on-scroll stagger-3">
              <a href="/suplementos" class="btn btn-accent btn-large">
                <span>Ver suplementos</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <a href="#filosofia" class="btn btn-outline btn-large">Nuestra filosofía</a>
            </div>
          </div>
          <div class="hero-visual animate-on-scroll stagger-2">
            <ProductMockup name="Logical" />
          </div>
        </div>
        <div class="hero-scroll">
          <span class="scroll-line" aria-hidden="true"></span>
        </div>
      </section>

      <!-- Trust ribbon -->
      <section class="trust-ribbon">
        <div class="container">
          <div class="trust-grid animate-on-scroll">
            <div class="trust-item-ribbon">
              <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 3h6M10 3v6l-4 8v2h12v-2l-4-8V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 14v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span>Testeado en laboratorio</span>
            </div>
            <div class="trust-item-ribbon">
              <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 3v18M3 12h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span>Single-ingredient</span>
            </div>
            <div class="trust-item-ribbon">
              <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Dosis clínicamente estudiadas</span>
            </div>
            <div class="trust-item-ribbon">
              <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M3 12h15l3-5v10H3V12z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <circle cx="7" cy="17" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="18" cy="17" r="1.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <span>Envíos a todo el Perú</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Featured products -->
      <section class="featured section">
        <div class="container">
          <SectionHeader
            label="Destacados"
            title="Nuestra línea de pureza"
            subtitle="Cada producto es un solo compuesto, en la dosis que la investigación recomienda. Nada más."
            align="center"
          />

          <div class="featured-grid">
            {featuredSupplements.map((supplement, index) => (
              <a href={`/suplementos/${supplement.id}`} class="featured-card animate-on-scroll stagger-${index + 1}">
                <div class="featured-card-visual">
                  <ProductMockup name={supplement.data.mockupLabel || supplement.data.title} />
                </div>
                <div class="featured-card-content">
                  <h3 class="featured-card-title">{supplement.data.title}</h3>
                  <p class="featured-card-description">{supplement.data.shortDescription || supplement.data.description}</p>
                  <span class="featured-card-link">Ver producto</span>
                </div>
              </a>
            ))}
          </div>

          <div class="featured-cta animate-on-scroll">
            <a href="/suplementos" class="btn btn-outline btn-large">Explorar catálogo completo</a>
          </div>
        </div>
      </section>

      <!-- Philosophy -->
      <section id="filosofia" class="philosophy section">
        <div class="container">
          <SectionHeader
            label="Filosofía"
            title="Tres pilares, cero ruido"
            subtitle="La industria del fitness promete magia. Nosotros vendemos lógica."
            align="center"
          />

          <div class="philosophy-grid">
            <div class="philosophy-item animate-on-scroll stagger-1">
              <span class="philosophy-number">01</span>
              <h3 class="philosophy-title">Pureza</h3>
              <p class="philosophy-text">
                Un solo compuesto por producto. Sin mezclas innecesarias, sin "fórmulas propietarias", sin rellenos. Sabes exactamente lo que consumes.
              </p>
            </div>
            <div class="philosophy-item animate-on-scroll stagger-2">
              <span class="philosophy-number">02</span>
              <h3 class="philosophy-title">Evidencia</h3>
              <p class="philosophy-text">
                Seleccionamos ingredientes con estudios clínicos en humanos. Cada dosis se justifica con literatura científica actual y verificable.
              </p>
            </div>
            <div class="philosophy-item animate-on-scroll stagger-3">
              <span class="philosophy-number">03</span>
              <h3 class="philosophy-title">Transparencia</h3>
              <p class="philosophy-text">
                Sin marketing engañoso. Publicamos ingredientes, análisis de laboratorio y referencias para que tomes decisiones informadas.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Testimonials -->
      <section class="testimonials section section-light">
        <TestimonialCarousel
          title="Lo que dicen nuestros clientes"
          subtitle="Profesionales y atletas que valoran la evidencia por encima del hype."
          testimonials={testimonials}
          light
        />
      </section>

      <!-- Lab transparency -->
      <section class="lab section">
        <div class="container lab-grid">
          <div class="lab-content animate-on-scroll">
            <span class="text-label lab-label">Transparencia</span>
            <h2 class="lab-title">Cada lote cuenta con respaldo analítico.</h2>
            <p class="lab-text">
              La calidad no es una promesa de marketing: es un proceso. Analizamos cada lote para verificar pureza, identidad, potencia y ausencia de contaminantes microbiológicos y metales pesados.
            </p>
            <ul class="lab-list">
              <li>Análisis de identidad por infrarrojo (FTIR)</li>
              <li>Verificación de pureza ≥ 99%</li>
              <li>Pruebas microbiológicas y de metales pesados</li>
              <li>Documentación disponible bajo solicitud</li>
            </ul>
            <a href="/nosotros" class="btn btn-outline">Conoce nuestro proceso</a>
          </div>
          <div class="lab-visual">
            <div class="lab-card animate-on-scroll stagger-2">
              <span class="lab-card-label">Certificado de análisis</span>
              <div class="lab-card-lines">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="lab-card-stamp">
                <span>APROBADO</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="home-faq section">
        <div class="container container-narrow">
          <SectionHeader
            label="FAQ"
            title="Preguntas frecuentes"
            subtitle="Respuestas directas sobre calidad, envíos y uso."
            align="center"
          />
          <div class="animate-on-scroll">
            <FAQ items={homeFaqs} />
          </div>
        </div>
      </section>

      <!-- Newsletter -->
      <section class="newsletter-section section">
        <div class="container newsletter-grid">
          <div class="animate-on-scroll">
            <Newsletter />
          </div>
          <div class="newsletter-visual animate-on-scroll stagger-2">
            <p class="quote-mark">“</p>
            <blockquote class="newsletter-quote">
              La suplementación efectiva no es magia. Es comprensión, consistencia y calidad.
            </blockquote>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-content animate-on-scroll">
            <h2 class="cta-title">Tu cuerpo merece lógica, no magia.</h2>
            <p class="cta-text">
              Explora nuestra línea de suplementos con respaldo científico y empieza a entrenar con evidencia de tu lado.
            </p>
            <a href="/suplementos" class="btn btn-accent btn-large">
              <span>Explorar suplementos</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
    <WhatsAppButton />
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding: calc(var(--space-24) + var(--space-8)) 0 var(--space-16);
    overflow: hidden;
  }

  .hero .atmospheric-glow {
    z-index: 0;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-visual {
      max-width: 260px;
      margin: 0 auto;
      order: -1;
    }
  }

  .hero-visual {
    transition: opacity 1s var(--ease-out-expo), transform 1s var(--ease-out-expo);
  }

  .js-enabled .hero-visual {
    opacity: 0;
    transform: translateY(30px) scale(0.96);
  }

  .js-enabled .hero-visual.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-5);
  }

  .hero-title {
    font-size: clamp(3.25rem, 8vw, 7rem);
    margin-bottom: var(--space-6);
  }

  .hero-title .text-serif {
    color: var(--color-accent);
  }

  .reveal-text .line {
    display: block;
    overflow: hidden;
  }

  .reveal-text .line-inner {
    display: block;
    transition: transform 1.1s var(--ease-out-expo);
  }

  .js-enabled .reveal-text .line-inner {
    transform: translateY(110%);
  }

  .js-enabled .reveal-text.is-visible .line-inner {
    transform: translateY(0);
  }

  .js-enabled .reveal-text .line:nth-child(2) .line-inner {
    transition-delay: 0.14s;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin-bottom: var(--space-8);
  }

  @media (max-width: 900px) {
    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .hero-actions {
      justify-content: center;
    }
  }

  .hero-scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.5), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.7); }
    50% { opacity: 0.8; transform: scaleY(1); }
  }

  /* Trust ribbon */
  .trust-ribbon {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
    justify-items: center;
  }

  @media (max-width: 900px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .trust-grid {
      grid-template-columns: 1fr;
      justify-items: start;
    }
  }

  .trust-item-ribbon {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .trust-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Featured */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
    gap: var(--space-5);
    margin-bottom: var(--space-10);
  }

  .featured-card {
    position: relative;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-base),
                transform var(--transition-base) var(--ease-out-expo),
                box-shadow var(--transition-base);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .featured-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(212, 184, 140, 0.08) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.8s var(--ease-out-expo);
    pointer-events: none;
  }

  .featured-card:hover {
    border-color: rgba(212, 184, 140, 0.35);
    transform: translateY(-6px);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
  }

  .featured-card:hover::before {
    transform: translateX(100%);
  }

  .featured-card-visual {
    padding: var(--space-8) var(--space-8) 0;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .featured-card:hover .featured-card-visual {
    transform: scale(1.03);
  }

  .featured-card-content {
    padding: var(--space-6) var(--space-8) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .featured-card-title {
    font-size: 1.375rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .featured-card-description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
    flex: 1;
  }

  .featured-card-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: var(--space-4);
  }

  .featured-cta {
    text-align: center;
  }

  /* Philosophy */
  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  @media (max-width: 768px) {
    .philosophy-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .philosophy-item {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .philosophy-number {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }

  .philosophy-title {
    font-size: 1.375rem;
    font-weight: 500;
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .philosophy-text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* Testimonials */
  .testimonials {
    padding: 0;
  }

  /* Lab */
  .lab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 900px) {
    .lab-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }

  .lab-label {
    display: block;
    margin-bottom: var(--space-4);
    color: var(--color-accent);
  }

  .lab-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
  }

  .lab-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .lab-list {
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .lab-list li {
    position: relative;
    padding-left: var(--space-6);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .lab-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .lab-visual {
    display: flex;
    justify-content: center;
  }

  .lab-card {
    width: 100%;
    max-width: 380px;
    aspect-ratio: 3/4;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .lab-card-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .lab-card-lines {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex: 1;
  }

  .lab-card-lines span {
    height: 1px;
    background: var(--color-border);
    transition: width 1s var(--ease-out-expo);
  }

  .lab-card-lines span:nth-child(1) { width: 100%; }
  .lab-card-lines span:nth-child(2) { width: 85%; }
  .lab-card-lines span:nth-child(3) { width: 92%; }
  .lab-card-lines span:nth-child(4) { width: 70%; }
  .lab-card-lines span:nth-child(5) { width: 95%; }

  .js-enabled .lab-card-lines span { width: 0; }

  .js-enabled .lab-card.is-visible .lab-card-lines span:nth-child(1) { width: 100%; transition-delay: 0.1s; }
  .js-enabled .lab-card.is-visible .lab-card-lines span:nth-child(2) { width: 85%; transition-delay: 0.22s; }
  .js-enabled .lab-card.is-visible .lab-card-lines span:nth-child(3) { width: 92%; transition-delay: 0.34s; }
  .js-enabled .lab-card.is-visible .lab-card-lines span:nth-child(4) { width: 70%; transition-delay: 0.46s; }
  .js-enabled .lab-card.is-visible .lab-card-lines span:nth-child(5) { width: 95%; transition-delay: 0.58s; }

  .lab-card-stamp {
    margin-top: auto;
    align-self: flex-end;
    width: 100px;
    height: 100px;
    border: 2px solid var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(-12deg);
  }

  .lab-card-stamp span {
    font-size: 0.6875rem;
