---

<div class="search-wrapper">
  <div class="search-input-wrapper">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <circle cx="7.5" cy="7.5" r="6" stroke="currentColor" stroke-width="1"/>
      <path d="M12 12l4.5 4.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    </svg>
    <input
      type="text"
      id="supplement-search"
      class="search-input input"
      placeholder="Buscar suplementos..."
      autocomplete="off"
    />
  </div>
</div>

<style>
  .search-wrapper {
    width: 100%;
    max-width: 480px;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: var(--space-4);
    opacity: 0.4;
    pointer-events: none;
  }

  .search-input {
    padding-left: var(--space-12);
  }
</style>
