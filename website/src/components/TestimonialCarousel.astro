---
export interface Testimonial {
  quote: string;
  author: string;
  role?: string;
  verified?: boolean;
  rating?: number;
}

export interface Props {
  testimonials: Testimonial[];
  title?: string;
  subtitle?: string;
  light?: boolean;
}

const { testimonials, title, subtitle, light = false } = Astro.props;
---

<section class={`testimonial-carousel-section ${light ? 'testimonial-carousel-section--light' : ''}`}>
  <div class="container">
    {(title || subtitle) && (
      <header class="carousel-header">
        {title && <h2 class="carousel-title">{title}</h2>}
        {subtitle && <p class="carousel-subtitle">{subtitle}</p>}
      </header>
    )}

    <div class="carousel-wrapper">
      <button
        type="button"
        class="carousel-arrow carousel-arrow--prev"
        aria-label="Anterior testimonio"
        data-role="carousel-prev"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="carousel-track" data-role="carousel-track">
        {testimonials.map((t) => (
          <article class="testimonial-slide">
            <div class="testimonial-stars" aria-label={`${t.rating || 5} de 5 estrellas`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class={`star ${i < (t.rating || 5) ? 'star--filled' : ''}`}
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <blockquote class="testimonial-quote">“{t.quote}”</blockquote>
            <footer class="testimonial-footer">
              <div class="testimonial-author-row">
                <span class="testimonial-author">{t.author}</span>
                {t.verified && <span class="verified-badge">Verified buyer</span>}
              </div>
              {t.role && <span class="testimonial-role">{t.role}</span>}
            </footer>
          </article>
        ))}
      </div>

      <button
        type="button"
        class="carousel-arrow carousel-arrow--next"
        aria-label="Siguiente testimonio"
        data-role="carousel-next"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <script is:inline>
    (function () {
      const wrappers = document.querySelectorAll('.carousel-wrapper');
      wrappers.forEach((wrapper) => {
        const track = wrapper.querySelector('[data-role="carousel-track"]');
        const prev = wrapper.querySelector('[data-role="carousel-prev"]');
        const next = wrapper.querySelector('[data-role="carousel-next"]');
        if (!track || !prev || !next) return;

        const getSlideWidth = () => {
          const slide = track.querySelector('.testimonial-slide');
          return slide ? slide.getBoundingClientRect().width + 20 : 360;
        };

        const AUTO_SCROLL_MS = 5000;
        let timer = null;

        function scrollNext() {
          const width = getSlideWidth();
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft + width >= maxScroll - 4) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: width, behavior: 'smooth' });
          }
        }

        function startAutoScroll() {
          stopAutoScroll();
          timer = setInterval(scrollNext, AUTO_SCROLL_MS);
        }

        function stopAutoScroll() {
          if (timer) {
            clearInterval(timer);
            timer = null;
          }
        }

        prev.addEventListener('click', () => {
          track.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
          startAutoScroll();
        });
        next.addEventListener('click', () => {
          scrollNext();
          startAutoScroll();
        });

        track.addEventListener('mouseenter', stopAutoScroll);
        track.addEventListener('mouseleave', startAutoScroll);
        track.addEventListener('touchstart', stopAutoScroll, { passive: true });
        track.addEventListener('touchend', startAutoScroll, { passive: true });

        startAutoScroll();
      });
    })();
  </script>
</section>

<style>
  .testimonial-carousel-section {
    padding: var(--space-20) 0;
  }

  .carousel-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .carousel-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: var(--space-4);
  }

  .carousel-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  .carousel-wrapper {
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: var(--space-5);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: var(--space-2) 0;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-slide {
    flex: 0 0 85%;
    max-width: 420px;
    scroll-snap-align: start;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .testimonial-slide {
      flex: 0 0 45%;
    }
  }

  @media (min-width: 1100px) {
    .testimonial-slide {
      flex: 0 0 32%;
    }
  }

  .testimonial-stars {
    display: flex;
    gap: var(--space-1);
  }

  .star {
    color: rgba(255, 255, 255, 0.2);
  }

  .star--filled {
    color: var(--color-accent);
  }

  .testimonial-quote {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.5;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
    border: none;
    padding: 0;
  }

  .testimonial-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial-author-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .testimonial-author {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .testimonial-role {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .verified-badge {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 999px;
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .carousel-arrow:hover {
    background: var(--color-surface-elevated);
    border-color: var(--color-border-hover);
  }

  .carousel-arrow--prev {
    left: calc(var(--space-5) * -1);
  }

  .carousel-arrow--next {
    right: calc(var(--space-5) * -1);
  }

  @media (min-width: 1100px) {
    .carousel-arrow {
      display: flex;
    }
  }

  /* Light variant — used inside the light section on the homepage */
  .testimonial-carousel-section--light .carousel-title {
    color: var(--color-light-text);
  }

  .testimonial-carousel-section--light .carousel-subtitle {
    color: var(--color-light-text-secondary);
  }

  .testimonial-carousel-section--light .testimonial-slide {
    background: var(--color-light-surface);
    border-color: var(--color-light-border);
  }

  .testimonial-carousel-section--light .star {
    color: rgba(10, 10, 10, 0.15);
  }

  .testimonial-carousel-section--light .star--filled {
    color: var(--color-accent);
  }

  .testimonial-carousel-section--light .testimonial-quote {
    color: var(--color-light-text);
  }

  .testimonial-carousel-section--light .testimonial-author {
    color: var(--color-light-text);
  }

  .testimonial-carousel-section--light .testimonial-role {
    color: var(--color-light-text-secondary);
  }

  .testimonial-carousel-section--light .verified-badge {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .testimonial-carousel-section--light .carousel-arrow {
    background: var(--color-light-surface);
    border-color: var(--color-light-border);
    color: var(--color-light-text);
  }

  .testimonial-carousel-section--light .carousel-arrow:hover {
    background: var(--color-light-bg);
    border-color: var(--color-light-border);
  }
</style>
