---
export interface Props {
  variant?: 'energy' | 'flow';
}

const { variant = 'energy' } = Astro.props;
---

<canvas class="product-hero-canvas" data-variant={variant} aria-hidden="true"></canvas>

<script>
  (function () {
    const canvas = document.querySelector('.product-hero-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const variant = canvas.dataset.variant || 'energy';
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const ACCENT = '212, 184, 140';
    const WHITE = '245, 242, 235';

    let width = 0;
    let height = 0;
    let rafId = 0;
    let isVisible = true;
    let time = 0;

    // Shared helpers
    function resize() {
      const parent = canvas.parentElement;
      width = parent ? parent.clientWidth : window.innerWidth;
      height = parent ? parent.clientHeight : window.innerHeight;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      initVariant();
    }

    function clear() {
      ctx.clearRect(0, 0, width, height);
    }

    function drawGlow(cx, cy, radius, alpha) {
      const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, radius);
      gradient.addColorStop(0, `rgba(${ACCENT}, ${alpha})`);
      gradient.addColorStop(1, 'transparent');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, width, height);
    }

    // =====================================================
    // ENERGY variant — radiating ATP-like core for Creatine
    // =====================================================
    let energyRays = [];
    let energyOrbitals = [];

    function initEnergy() {
      energyRays = [];
      const count = 18;
      for (let i = 0; i < count; i++) {
        energyRays.push({
          angle: (Math.PI * 2 * i) / count,
          length: Math.max(width, height) * 0.55,
          speed: 0.0008 + Math.random() * 0.0015,
          offset: Math.random() * Math.PI * 2,
          alpha: 0.12 + Math.random() * 0.18,
        });
      }

      energyOrbitals = [];
      const rings = 4;
      for (let i = 0; i < rings; i++) {
        const radius = 80 + i * 55;
        const particles = 4 + i * 2;
        for (let j = 0; j < particles; j++) {
          energyOrbitals.push({
            radius,
            angle: (Math.PI * 2 * j) / particles,
            speed: (0.003 + i * 0.0012) * (j % 2 === 0 ? 1 : -1),
            size: 2.4 - i * 0.3,
            ringIndex: i,
          });
        }
      }
    }

    function drawEnergy() {
      const cx = width * 0.45;
      const cy = height * 0.5;

      drawGlow(cx, cy, Math.max(width, height) * 0.55, 0.12);

      // Radiating rays
      energyRays.forEach((ray) => {
        const pulse = 0.5 + 0.5 * Math.sin(time * 1.5 + ray.offset);
        const alpha = ray.alpha * (0.6 + pulse * 0.4);
        const x2 = cx + Math.cos(ray.angle + time * ray.speed) * ray.length;
        const y2 = cy + Math.sin(ray.angle + time * ray.speed) * ray.length;

        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(x2, y2);
        ctx.strokeStyle = `rgba(${ACCENT}, ${alpha})`;
        ctx.lineWidth = 1.2;
        ctx.stroke();
      });

      // Rings
      for (let i = 0; i < 4; i++) {
        const radius = 80 + i * 55;
        ctx.beginPath();
        ctx.arc(cx, cy, radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${ACCENT}, ${0.15 - i * 0.02})`;
        ctx.lineWidth = 1.2;
        ctx.stroke();
      }

      // Orbital particles
      energyOrbitals.forEach((p) => {
        p.angle += p.speed;
        const px = cx + Math.cos(p.angle) * p.radius;
        const py = cy + Math.sin(p.angle) * p.radius;
        ctx.beginPath();
        ctx.arc(px, py, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${WHITE}, ${0.7 - p.ringIndex * 0.1})`;
        ctx.fill();
      });

      // Central core
      const corePulse = 1 + 0.15 * Math.sin(time * 2);
      ctx.beginPath();
      ctx.arc(cx, cy, 10 * corePulse, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${ACCENT}, 0.35)`;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(cx, cy, 4 * corePulse, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${WHITE}, 0.9)`;
      ctx.fill();
    }

    // =====================================================
    // FLOW variant — flowing sine waves for Citrulline
    // =====================================================
    let flowWaves = [];
    let flowParticles = [];

    function initFlow() {
      flowWaves = [];
      const waveCount = 6;
      for (let i = 0; i < waveCount; i++) {
        flowWaves.push({
          y: (height / (waveCount + 1)) * (i + 1),
          amplitude: 18 + i * 4,
          frequency: 0.008 + i * 0.0015,
          phase: i * 0.9,
          speed: 0.015 + i * 0.004,
          alpha: 0.2 + i * 0.08,
        });
      }

      flowParticles = [];
      for (let i = 0; i < 40; i++) {
        flowParticles.push({
          x: Math.random() * width,
          waveIndex: Math.floor(Math.random() * waveCount),
          speed: 0.8 + Math.random() * 1.2,
          size: 1.6 + Math.random() * 1.4,
          offset: Math.random() * Math.PI * 2,
        });
      }
    }

    function drawFlow() {
      // Vertical gradient glow from left
      const gradient = ctx.createLinearGradient(0, 0, width, 0);
      gradient.addColorStop(0, `rgba(${ACCENT}, 0.08)`);
      gradient.addColorStop(0.5, 'transparent');
      gradient.addColorStop(1, `rgba(${ACCENT}, 0.04)`);
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, width, height);

      // Waves
      flowWaves.forEach((wave) => {
        ctx.beginPath();
        for (let x = 0; x <= width; x += 4) {
          const y = wave.y + Math.sin(x * wave.frequency + time * wave.speed + wave.phase) * wave.amplitude;
          if (x === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = `rgba(${ACCENT}, ${wave.alpha})`;
        ctx.lineWidth = 1.5;
        ctx.stroke();
      });

      // Particles flowing along waves
      flowParticles.forEach((p) => {
        const wave = flowWaves[p.waveIndex];
        p.x += p.speed;
        if (p.x > width + 20) p.x = -20;

        const y = wave.y + Math.sin(p.x * wave.frequency + time * wave.speed + wave.phase) * wave.amplitude;
        const glow = 0.5 + 0.5 * Math.sin(time * 2 + p.offset);

        ctx.beginPath();
        ctx.arc(p.x, y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${WHITE}, ${0.5 + glow * 0.3})`;
        ctx.fill();
      });
    }

    // =====================================================
    // Main loop
    // =====================================================
    function initVariant() {
      if (variant === 'flow') initFlow();
      else initEnergy();
    }

    function drawVariant() {
      if (variant === 'flow') drawFlow();
      else drawEnergy();
    }

    function animate() {
      if (!isVisible) return;
      clear();
      time += 0.02;
      drawVariant();
      rafId = requestAnimationFrame(animate);
    }

    resize();
    animate();

    window.addEventListener('resize', resize, { passive: true });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!isVisible) {
              isVisible = true;
              animate();
            }
          } else {
            isVisible = false;
            cancelAnimationFrame(rafId);
          }
        });
      },
      { threshold: 0 }
    );
    observer.observe(canvas);
  })();
</script>

<style>
  .product-hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.95;
  }
</style>
