---
import { getWhatsAppUrl, WHATSAPP_MESSAGE } from '../data/contact';

interface Props {
  product?: string;
  class?: string;
  variant?: 'button' | 'link';
}

const { product, class: className = '', variant = 'link' } = Astro.props;

const message = product
  ? `Hola, quiero consultar por ${product} de Logical Nutrition.`
  : WHATSAPP_MESSAGE;

const whatsappUrl = getWhatsAppUrl(message);
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={`${variant === 'button' ? 'btn btn-accent' : ''} ${className}`.trim()}
>
  {Astro.slots.has('default') ? <slot /> : 'Comprar por WhatsApp'}
</a>
