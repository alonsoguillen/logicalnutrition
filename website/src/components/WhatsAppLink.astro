---
interface Props {
  product?: string;
  class?: string;
  children?: any;
  variant?: 'button' | 'link';
}

const WHATSAPP_NUMBER = '56912345678';

const { product, class: className = '', variant = 'link' } = Astro.props;

const baseMessage = product
  ? `Hola, quiero consultar por ${product} de Logical Nutrition.`
  : 'Hola, quiero consultar por los suplementos de Logical Nutrition.';

const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(baseMessage)}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={`${variant === 'button' ? 'btn btn-accent' : ''} ${className}`.trim()}
>
  {Astro.slots.has('default') ? <slot /> : 'Comprar por WhatsApp'}
</a>
