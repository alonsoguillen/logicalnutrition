---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href="/" class={`logo-link ${className}`} aria-label="Logical Nutrition - Inicio">
  <svg viewBox="0 0 340 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg">
    <!-- Geometric mark: hexagon with internal line suggesting molecular structure / L shape -->
    <g class="logo-mark">
      <polygon points="18,4 32,12 32,28 18,36 4,28 4,12" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <line x1="18" y1="4" x2="18" y2="20" stroke="currentColor" stroke-width="1.5"/>
      <line x1="18" y1="20" x2="32" y2="28" stroke="currentColor" stroke-width="1.5"/>
    </g>
    <!-- Text -->
    <text x="44" y="26" class="logo-text" fill="currentColor">LOGICAL NUTRITION</text>
  </svg>
</a>

<style>
  .logo-link {
    display: inline-block;
    text-decoration: none;
    color: inherit;
  }
  .logo-svg {
    height: 28.8px;
    width: auto;
    display: block;
  }
  .logo-mark {
    transition: transform 0.5s var(--ease-out-expo);
    transform-origin: 18px 20px;
  }
  .logo-link:hover .logo-mark {
    transform: rotate(30deg);
  }
  .logo-text {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
</style>
